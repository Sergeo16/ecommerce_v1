// ============ MONEY MACHINE — Extension du schéma Prisma ============
// À fusionner dans schema.prisma (après les modèles existants)
// Migrations à créer séparément pour chaque bloc si besoin

// ============ ABONNEMENTS VENDEURS ============
enum SellerPlanSlug {
  FREE
  PRO
  ELITE
}

model SellerSubscriptionPlan {
  id          String         @id @default(cuid())
  slug        SellerPlanSlug @unique
  name        String
  description String?        @db.Text
  commissionPercentOverride Decimal? @map("commission_percent_override") @db.Decimal(5, 2) // si null = règle globale
  monthlyPrice Decimal       @map("monthly_price") @db.Decimal(12, 2)
  currency    String         @default("XOF")
  features    Json?          // ["analytics", "badge_premium", "top_visibility"]
  isActive    Boolean        @default(true) @map("is_active")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  subscriptions SellerSubscription[]

  @@map("seller_subscription_plans")
}

enum SellerSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model SellerSubscription {
  id                   String                    @id @default(cuid())
  companyProfileId     String                    @unique @map("company_profile_id")
  companyProfile       CompanyProfile            @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  planId               String                    @map("plan_id")
  plan                 SellerSubscriptionPlan    @relation(fields: [planId], references: [id])
  status               SellerSubscriptionStatus  @default(ACTIVE)
  currentPeriodStart   DateTime                  @map("current_period_start")
  currentPeriodEnd     DateTime                  @map("current_period_end")
  stripeSubscriptionId String?                   @map("stripe_subscription_id")
  cancelAtPeriodEnd    Boolean                   @default(false) @map("cancel_at_period_end")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  @@index([status])
  @@map("seller_subscriptions")
}

// ============ PUBLICITÉ INTERNE ============
enum AdPlacementType {
  PRODUCT_SPOTLIGHT
  CATEGORY_TOP
  BANNER_HOME
  SEARCH_TOP
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model AdCampaign {
  id              String            @id @default(cuid())
  companyProfileId String           @map("company_profile_id")
  companyProfile   CompanyProfile   @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  name            String
  placementType   AdPlacementType   @map("placement_type")
  targetCategoryId String?          @map("target_category_id") // pour CATEGORY_TOP
  targetProductId  String?          @map("target_product_id")  // pour PRODUCT_SPOTLIGHT
  status          AdCampaignStatus  @default(DRAFT)
  budgetTotal     Decimal           @map("budget_total") @db.Decimal(12, 2)
  bidCpc          Decimal           @map("bid_cpc") @db.Decimal(10, 4)
  startAt         DateTime          @map("start_at")
  endAt           DateTime          @map("end_at")
  impressions     Int               @default(0)
  clicks          Int               @default(0)
  conversions     Int               @default(0)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([companyProfileId])
  @@index([status, placementType])
  @@map("ad_campaigns")
}

// ============ FIDÉLITÉ & GAMIFICATION ============
model LoyaltyProgram {
  id          String   @id @default(cuid())
  name        String
  pointsPerXof Decimal @map("points_per_xof") @db.Decimal(10, 4) // ex: 1 point / 100 XOF
  isActive    Boolean  @default(true) @map("is_active")
  config      Json?    // redemption rules, tiers
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userPoints  UserLoyaltyPoints[]
  @@map("loyalty_programs")
}

model UserLoyaltyPoints {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId String   @map("program_id")
  program   LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  points    Int      @default(0)
  lifetimeEarned Int  @default(0) @map("lifetime_earned")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_loyalty_points")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey  String   @map("badge_key") // first_purchase, top_referrer, etc.
  earnedAt  DateTime @default(now()) @map("earned_at")

  @@unique([userId, badgeKey])
  @@index([userId])
  @@map("user_badges")
}

model UserLevel {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level       Int      @default(1)
  xp          Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_levels")
}

// ============ PARRAINAGE MULTI-NIVEAUX ============
model ReferralTree {
  id           String   @id @default(cuid())
  referrerId   String   @map("referrer_id")
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId   String   @unique @map("referred_id")
  referred     User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  level        Int      @default(1)
  referralCode String   @map("referral_code")
  status       String   @default("PENDING") // PENDING | QUALIFIED | PAID
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([referrerId])
  @@map("referral_trees")
}

// ============ ESCROW (optionnel) ============
enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

model EscrowTransaction {
  id            String       @id @default(cuid())
  orderId       String       @unique @map("order_id")
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(12, 2)
  currency      String       @default("XOF")
  status        EscrowStatus @default(HELD)
  releasedAt    DateTime?    @map("released_at")
  releaseReason String?      @map("release_reason") // DELIVERY_CONFIRMED | DISPUTE_WON_SELLER | REFUND
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("escrow_transactions")
}

// ============ KYC VENDEURS ============
enum KycStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model KycSubmission {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyProfileId  String?   @map("company_profile_id")
  documentType      String    @map("document_type") // ID_CARD, BUSINESS_REGISTRATION
  documentUrl      String    @map("document_url")
  status            KycStatus @default(PENDING)
  reviewedBy        String?   @map("reviewed_by")
  reviewedAt        DateTime? @map("reviewed_at")
  rejectionReason   String?   @map("rejection_reason") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("kyc_submissions")
}

// ============ LITIGES / ARBITRAGE ============
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUND
  RESOLVED_NO_REFUND
  CLOSED
}

model Dispute {
  id           String        @id @default(cuid())
  orderId      String        @map("order_id")
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  raisedBy     String        @map("raised_by") // userId (client)
  reason       String        @db.Text
  status       DisputeStatus @default(OPEN)
  resolution   String?       @db.Text
  refundAmount Decimal?      @map("refund_amount") @db.Decimal(12, 2)
  resolvedBy  String?        @map("resolved_by")
  resolvedAt  DateTime?     @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([status])
  @@map("disputes")
}

// ============ 2FA ============
model UserTwoFactor {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secretEncrypted String @map("secret_encrypted") // TOTP secret chiffré
  backupCodes  String[] @map("backup_codes")     // hash des codes de secours
  enabledAt    DateTime? @map("enabled_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("user_two_factors")
}

// ============ FLASH SALES / URGENCE ============
// Option 1 : champs sur Product
// promoEndsAt DateTime? @map("promo_end_at")
// promoPrice  Decimal?  @map("promo_price")
// Option 2 : table dédiée (pour enchères / flash)
model FlashSale {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  promoPrice  Decimal  @map("promo_price") @db.Decimal(12, 2)
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  maxQuantity Int?     @map("max_quantity")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([endAt])
  @@map("flash_sales")
}

// ============ RÈGLES COMMISSION AVANCÉES (optionnel en DB) ============
// Sinon garder tout en Settings (JSON) pour flexibilité
model CommissionRule {
  id          String   @id @default(cuid())
  scope       String   // GLOBAL | CATEGORY | COMPANY | ZONE
  scopeId     String?  @map("scope_id")
  platformPercent Decimal @map("platform_percent") @db.Decimal(5, 2)
  conditions  Json?    // volume min, zone, etc.
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([scope, scopeId])
  @@map("commission_rules")
}

