# Database (PostgreSQL)
DATABASE_URL="postgresql://marketplace:marketplace@localhost:5432/marketplace"

# Redis (BullMQ, cache, rate limit)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-min-32-chars-production"
REFRESH_SECRET="refresh-change-me-min-32-chars"

# Stripe (optionnel)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# S3 / Cloudflare R2 (optionnel)
# Pour AWS S3 :
#   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION, S3_BUCKET
# Pour Cloudflare R2 : voir CLOUDFLARE_R2_SETUP.md
#   S3_ACCESS_KEY, S3_SECRET_KEY, S3_ENDPOINT, S3_REGION=auto, S3_BUCKET, S3_PUBLIC_BASE_URL
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-1"
S3_BUCKET="marketplace-uploads"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""
S3_REGION="auto"
S3_PUBLIC_BASE_URL=""

# Mobile Money (mock par défaut si KKiaPay non configuré)
MOBILE_MONEY_MOCK="true"
# MTN_MOMO_API_KEY=""
# MTN_MOMO_USER_ID=""

# KKiaPay — agrégateur Mobile Money (MTN, Moov) et cartes
# Si les 3 clés sont renseignées, le checkout utilise KKiaPay pour paiement total / acompte (XOF).
# Doc : https://docs.kkiapay.me/v1/
KKIAPAY_PUBLIC_KEY=""
KKIAPAY_PRIVATE_KEY=""
KKIAPAY_SECRET_KEY=""
KKIAPAY_SANDBOX="true"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Premier Super Admin (production uniquement) — utilisé par `npm run bootstrap:admin`
# SUPER_ADMIN_EMAIL="admin@votredomaine.com"
# SUPER_ADMIN_PASSWORD=""

# Sentry (optionnel)
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ElasticSearch (optionnel, recherche)
ELASTICSEARCH_URL="http://localhost:9200"
